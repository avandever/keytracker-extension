{
  "manifest_version": 3,
  "name": "KeyTracker",
  "version": "1.0.0",
  "description": "Captures and submits KeyForge game data from thecrucible.online to Bear Tracks.",
  "homepage_url": "https://tracker.ancientbearrepublic.com",
  "privacy_policy": "https://tracker.ancientbearrepublic.com/privacy",
  "permissions": ["storage"],
  "host_permissions": [
    "*://thecrucible.online/*",
    "https://tracker.ancientbearrepublic.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://thecrucible.online/*"],
      "js": ["inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["*://thecrucible.online/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "KeyTracker",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
